<%= form_with(model: youtube_channel, local: true) do |f| %>
  <div class="space-y-4">
    <div>
      <%= f.label :name, class: "block text-sm font-medium" %>
      <%= f.text_field :name, class: "mt-1 block w-full rounded border px-3 py-2" %>
    </div>

    <div>
      <%= f.label :external_id, "YouTube Channel ID", class: "block text-sm font-medium" %>
      <%= f.text_field :external_id, class: "mt-1 block w-full rounded border px-3 py-2" %>
      <p class="text-xs text-gray-500 mt-1">Optional: a channel ID like UCxxxxx</p>
    </div>

    <div>
      <%= f.label :description, class: "block text-sm font-medium" %>
      <%= f.text_area :description, rows: 4, class: "mt-1 block w-full rounded border px-3 py-2" %>
    </div>

    <div class="grid grid-cols-2 gap-4">
      <div>
        <%= f.label :status, class: "block text-sm font-medium" %>
        <%= f.select :status, YoutubeChannel::STATUSES.map { |s| [s.humanize, s] }, {}, class: "mt-1 block w-full rounded border px-3 py-2" %>
      </div>

      <div>
        <%= f.label :published_at, class: "block text-sm font-medium" %>
        <%= f.datetime_local_field :published_at, class: "mt-1 block w-full rounded border px-3 py-2" %>
      </div>
    </div>

    <div>
      <%= f.submit class: "px-4 py-2 bg-blue-600 text-white rounded" %>
    </div>
  </div>
<% end %>
