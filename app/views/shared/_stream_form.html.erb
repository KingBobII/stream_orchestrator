<%# shared/_stream_form.html.erb %>
<%# Locals: stream (required), scope (optional) e.g. [:admin, @stream] or [:stream_operator, @stream] %>

<% form_model = local_assigns[:scope] || stream %>

<%= form_with(model: form_model, local: true) do |f| %>
  <% if stream.errors.any? %>
    <div class="mb-4 bg-red-50 border border-red-200 p-3 rounded">
      <h4 class="font-semibold text-red-700">Please fix the following:</h4>
      <ul class="mt-2 text-sm text-red-600">
        <% stream.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="space-y-4">
    <div>
      <%= f.label :title, class: "block text-sm font-medium" %>
      <%= f.text_field :title, class: "mt-1 block w-full rounded border px-3 py-2" %>
    </div>

    <div>
      <%= f.label :youtube_channel_id, "Channel", class: "block text-sm font-medium" %>
      <%= f.collection_select :youtube_channel_id,
            YoutubeChannel.all.order(:name),
            :id, :name,
            { prompt: "Select channel" },
            class: "mt-1 block w-full rounded border px-3 py-2" %>
    </div>

    <div>
      <%= f.label :description, class: "block text-sm font-medium" %>
      <%= f.text_area :description, rows: 4, class: "mt-1 block w-full rounded border px-3 py-2" %>
    </div>

    <div class="grid grid-cols-3 gap-4">
      <div>
        <%= f.label :status, class: "block text-sm font-medium" %>
        <%= f.select :status,
            Stream::STATUSES.map { |s| [s.humanize, s] },
            {},
            class: "mt-1 block w-full rounded border px-3 py-2" %>
      </div>

      <div>
        <%= f.label :scheduled_at, class: "block text-sm font-medium" %>
        <%= f.datetime_local_field :scheduled_at,
              value: (stream.scheduled_at&.in_time_zone("Africa/Johannesburg")&.strftime("%Y-%m-%dT%H:%M")),
              class: "mt-1 block w-full rounded border px-3 py-2" %>
        <p class="text-xs text-gray-500 mt-1">Displayed in Africa/Johannesburg — saved in UTC.</p>
      </div>

      <div>
        <%= f.label :visibility, class: "block text-sm font-medium" %>
        <%= f.select :visibility,
            Stream::VISIBILITIES.map { |v| [v.capitalize, v] },
            {},
            class: "mt-1 block w-full rounded border px-3 py-2" %>
      </div>
    </div>

    <div class="flex items-center space-x-3">
      <%= f.submit class: "px-4 py-2 bg-blue-600 text-white rounded" %>
      <%# Optional cancel link (will be ignored if not available in the calling view) %>
      <% if local_assigns[:cancel_path] %>
        <%= link_to "Cancel", local_assigns[:cancel_path], class: "text-sm text-gray-500" %>
      <% end %>
    </div>
  </div>
<% end %>
