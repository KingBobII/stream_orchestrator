<div class="mb-8 flex flex-col gap-4 sm:flex-row sm:items-end sm:justify-between">
  <div>
    <p class="text-sm font-medium uppercase tracking-wide text-gray-500">Stream Operator</p>
    <h2 class="mt-1 text-3xl font-bold text-gray-900">Dashboard</h2>
    <p class="mt-2 text-sm text-gray-600">
      View your assigned channels and upcoming streams.
    </p>
  </div>

  <div class="grid grid-cols-2 gap-3 sm:grid-cols-3">
    <div class="rounded-2xl border bg-white px-4 py-3 shadow-sm">
      <p class="text-xs uppercase tracking-wide text-gray-500">Channels</p>
      <p class="mt-1 text-2xl font-semibold text-gray-900"><%= @youtube_channels.count %></p>
    </div>

    <div class="rounded-2xl border bg-white px-4 py-3 shadow-sm">
      <p class="text-xs uppercase tracking-wide text-gray-500">Streams</p>
      <p class="mt-1 text-2xl font-semibold text-gray-900"><%= @streams.count %></p>
    </div>

    <div class="rounded-2xl border bg-white px-4 py-3 shadow-sm">
      <p class="text-xs uppercase tracking-wide text-gray-500">Upcoming</p>
      <p class="mt-1 text-2xl font-semibold text-gray-900">
        <%= @streams.select { |s| stream_start_time(s).present? && stream_start_time(s) >= Time.current }.count %>
      </p>
    </div>
  </div>
</div>

<div class="rounded-2xl border border-gray-200 bg-white p-6 shadow-sm">
  <h3 class="text-lg font-semibold text-gray-900">Upcoming streams</h3>

  <% if @streams.any? %>
    <div class="mt-4 space-y-4">
      <% @streams.each do |stream| %>
        <div class="rounded-xl border border-gray-200 p-4">
          <div class="flex items-start justify-between gap-4">
            <div>
              <p class="font-medium text-gray-900"><%= stream.title %></p>
              <p class="text-sm text-gray-600">
                <%= stream.youtube_channel&.name || "Unassigned" %>
              </p>
              <p class="mt-1 text-sm text-gray-500">
                <%= format_stream_datetime(stream_start_time(stream)) %>
              </p>
            </div>

            <%= link_to "View", stream_operator_stream_path(stream),
                        class: "rounded-lg border border-gray-300 px-3 py-2 text-sm font-medium text-gray-700 hover:bg-gray-50" %>
          </div>
        </div>
      <% end %>
    </div>
  <% else %>
    <p class="mt-4 text-sm text-gray-600">No streams found.</p>
  <% end %>
</div>
