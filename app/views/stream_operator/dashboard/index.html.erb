<div class="grid grid-cols-3 gap-6">
  <div class="col-span-2 bg-white p-4 rounded shadow">
    <h2 class="text-lg font-semibold">My Channels</h2>
    <% if @my_channels.present? %>
      <ul class="mt-3 space-y-2">
        <% @my_channels.each do |ch| %>
          <li class="border rounded p-2">
            <%= link_to ch.name, stream_operator_youtube_channel_path(ch), class: "font-medium" %>
            <div class="text-sm text-gray-500"><%= truncate(ch.description, length: 90) %></div>
          </li>
        <% end %>
      </ul>
    <% else %>
      <p class="text-sm text-gray-500">You don't own any channels yet.</p>
    <% end %>
  </div>

  <aside class="bg-white p-4 rounded shadow">
    <h3 class="font-semibold">Upcoming Streams</h3>
    <ul class="mt-3 space-y-2">
      <% @upcoming_streams&.each do |s| %>
        <li class="text-sm">
          <%= s.title %> — <%= s.scheduled_at.strftime("%b %d %H:%M") if s.scheduled_at %>
        </li>
      <% end %>
    </ul>
  </aside>
</div>
