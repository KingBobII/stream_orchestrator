<!-- app/views/stream_operator/streams/index.html.erb -->
<div class="mx-auto max-w-7xl px-4 py-8 sm:px-6 lg:px-8">
  <div class="mb-8 flex flex-col gap-4 sm:flex-row sm:items-end sm:justify-between">
    <div>
      <p class="text-sm font-medium uppercase tracking-wide text-gray-500">Stream Operator</p>
      <h1 class="mt-1 text-3xl font-bold text-gray-900">Schedule</h1>
      <p class="mt-2 text-sm text-gray-600">
        View the exact streams created by admin for your assigned YouTube channels.
      </p>
    </div>

    <div class="grid grid-cols-2 gap-3 sm:grid-cols-3">
      <div class="rounded-2xl border bg-white px-4 py-3 shadow-sm">
        <p class="text-xs uppercase tracking-wide text-gray-500">Channels</p>
        <p class="mt-1 text-2xl font-semibold text-gray-900"><%= @youtube_channels.count %></p>
      </div>
      <div class="rounded-2xl border bg-white px-4 py-3 shadow-sm">
        <p class="text-xs uppercase tracking-wide text-gray-500">Streams</p>
        <p class="mt-1 text-2xl font-semibold text-gray-900"><%= @streams.count %></p>
      </div>
      <div class="rounded-2xl border bg-white px-4 py-3 shadow-sm">
        <p class="text-xs uppercase tracking-wide text-gray-500">Upcoming</p>
        <p class="mt-1 text-2xl font-semibold text-gray-900">
          <%= @streams.select { |s| stream_start_time(s).present? && stream_start_time(s) >= Time.current }.count %>
        </p>
      </div>
    </div>
  </div>

  <% if @streams.any? %>
    <div class="overflow-hidden rounded-2xl border border-gray-200 bg-white shadow-sm">
      <div class="overflow-x-auto">
        <table class="min-w-[1700px] w-full divide-y divide-gray-200">
          <thead class="bg-gray-50">
            <tr>
              <th class="px-6 py-4 text-left text-xs font-semibold uppercase tracking-wide text-gray-500">Date / Time</th>
              <th class="px-6 py-4 text-left text-xs font-semibold uppercase tracking-wide text-gray-500">Title</th>
              <th class="px-6 py-4 text-left text-xs font-semibold uppercase tracking-wide text-gray-500">Channel</th>
              <th class="px-6 py-4 text-left text-xs font-semibold uppercase tracking-wide text-gray-500">Venue</th>
              <th class="px-6 py-4 text-left text-xs font-semibold uppercase tracking-wide text-gray-500">Stream Key</th>
              <th class="px-6 py-4 text-left text-xs font-semibold uppercase tracking-wide text-gray-500">Ingest URL</th>
              <th class="px-6 py-4 text-left text-xs font-semibold uppercase tracking-wide text-gray-500">Watch URL</th>
              <th class="px-6 py-4 text-left text-xs font-semibold uppercase tracking-wide text-gray-500">Status</th>
              <th class="px-6 py-4 text-right text-xs font-semibold uppercase tracking-wide text-gray-500">Action</th>
            </tr>
          </thead>

          <tbody class="divide-y divide-gray-100 bg-white">
            <% @streams.each do |stream| %>
              <tr class="align-top hover:bg-gray-50">
                <td class="px-6 py-5 text-sm text-gray-700 whitespace-nowrap">
                  <div class="font-medium text-gray-900"><%= format_stream_datetime(stream_start_time(stream)) %></div>
                  <% if stream_end_time(stream).present? %>
                    <div class="mt-1 text-xs text-gray-500">
                      Ends: <%= format_stream_datetime(stream_end_time(stream)) %>
                    </div>
                  <% end %>
                </td>

                <td class="px-6 py-5 text-sm text-gray-900">
                  <div class="min-w-[240px] font-medium leading-6">
                    <%= stream.title %>
                  </div>
                  <% if stream.respond_to?(:description) && stream.description.present? %>
                    <div class="mt-2 max-w-[280px] text-xs leading-5 text-gray-500">
                      <%= stream.description %>
                    </div>
                  <% end %>
                </td>

                <td class="px-6 py-5 text-sm text-gray-700">
                  <div class="min-w-[220px] whitespace-normal leading-6">
                    <%= stream.youtube_channel&.name || "Unassigned" %>
                  </div>
                </td>

                <td class="px-6 py-5 text-sm text-gray-700">
                  <div class="min-w-[220px] whitespace-normal leading-6">
                    <%= stream_venue_value(stream) %>
                  </div>
                </td>

                <td class="px-6 py-5 text-sm">
                  <div class="min-w-[260px] max-w-[320px] break-all rounded-xl bg-gray-100 px-4 py-3 font-mono text-xs leading-5 text-gray-800">
                    <%= stream_key_value(stream) %>
                  </div>
                </td>

                <td class="px-6 py-5 text-sm">
                  <div class="min-w-[260px] max-w-[320px] break-all rounded-xl bg-gray-100 px-4 py-3 font-mono text-xs leading-5 text-gray-800">
                    <%= stream_url_value(stream) %>
                  </div>
                </td>

                <td class="px-6 py-5 text-sm">
                  <div class="min-w-[260px] max-w-[320px] break-all rounded-xl bg-gray-100 px-4 py-3 font-mono text-xs leading-5 text-gray-800">
                    <%= stream_watch_url_value(stream) %>
                  </div>
                </td>

                <td class="px-6 py-5 text-sm">
                  <% status = stream.respond_to?(:status) ? stream.status : nil %>
                  <% badge_class =
                      case status
                      when "live" then "bg-green-100 text-green-800"
                      when "scheduled" then "bg-blue-100 text-blue-800"
                      when "ended" then "bg-gray-100 text-gray-700"
                      when "cancelled" then "bg-red-100 text-red-800"
                      else "bg-yellow-100 text-yellow-800"
                      end %>
                  <span class="inline-flex rounded-full px-2.5 py-1 text-xs font-semibold <%= badge_class %>">
                    <%= status.present? ? status.titleize : "Unknown" %>
                  </span>
                </td>

                <td class="px-6 py-5 text-right text-sm whitespace-nowrap">
                  <%= link_to "View", stream_operator_stream_path(stream),
                              class: "inline-flex items-center rounded-lg border border-gray-300 px-3 py-2 text-sm font-medium text-gray-700 hover:bg-gray-50" %>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    </div>
  <% else %>
    <div class="rounded-2xl border border-dashed border-gray-300 bg-white p-10 text-center shadow-sm">
      <h2 class="text-lg font-semibold text-gray-900">No streams yet</h2>
      <p class="mt-2 text-sm text-gray-600">
        Once admin creates streams for one of your assigned channels, they will appear here automatically.
      </p>
    </div>
  <% end %>
</div>
