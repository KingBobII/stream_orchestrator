<div class="bg-white rounded-lg shadow p-4">
  <div class="mb-4">
    <h1 class="text-2xl font-bold text-gray-900">Production Schedule</h1>
    <p class="text-sm text-gray-500">
      Full schedule view for the production team.
    </p>
  </div>

  <% if @streams.present? %>
    <div class="overflow-x-auto">
      <table class="min-w-full divide-y divide-gray-200">
        <thead class="bg-gray-50">
          <tr>
            <th class="px-4 py-3 text-left text-xs font-semibold text-gray-600 uppercase tracking-wide">Title</th>
            <th class="px-4 py-3 text-left text-xs font-semibold text-gray-600 uppercase tracking-wide">Channel</th>
            <th class="px-4 py-3 text-left text-xs font-semibold text-gray-600 uppercase tracking-wide">Scheduled At</th>
            <th class="px-4 py-3 text-left text-xs font-semibold text-gray-600 uppercase tracking-wide">Status</th>
            <th class="px-4 py-3 text-left text-xs font-semibold text-gray-600 uppercase tracking-wide">Visibility</th>
            <th class="px-4 py-3 text-left text-xs font-semibold text-gray-600 uppercase tracking-wide">Description</th>
            <th class="px-4 py-3 text-left text-xs font-semibold text-gray-600 uppercase tracking-wide">Ingestion URL</th>
            <th class="px-4 py-3 text-left text-xs font-semibold text-gray-600 uppercase tracking-wide">Actions</th>
          </tr>
        </thead>

        <tbody class="bg-white divide-y divide-gray-200">
          <% @streams.each do |stream| %>
            <tr>
              <td class="px-4 py-3 text-sm font-medium text-gray-900">
                <%= stream.title %>
              </td>

              <td class="px-4 py-3 text-sm text-gray-700">
                <%= stream.youtube_channel&.name || "-" %>
              </td>

              <td class="px-4 py-3 text-sm text-gray-700">
                <%= stream.scheduled_at ? l(stream.scheduled_at, format: :long) : "-" %>
              </td>

              <td class="px-4 py-3 text-sm">
                <% badge_class =
                  case stream.status
                  when "live" then "bg-red-100 text-red-700"
                  when "scheduled" then "bg-blue-100 text-blue-700"
                  when "ended" then "bg-gray-100 text-gray-700"
                  when "cancelled" then "bg-yellow-100 text-yellow-700"
                  else "bg-gray-100 text-gray-700"
                  end
                %>

                <span class="inline-flex px-2 py-1 text-xs font-semibold rounded <%= badge_class %>">
                  <%= stream.status.to_s.upcase %>
                </span>
              </td>

              <td class="px-4 py-3 text-sm text-gray-700">
                <%= stream.visibility.to_s.titleize %>
              </td>

              <td class="px-4 py-3 text-sm text-gray-700 max-w-md">
                <div class="truncate">
                  <%= stream.description.presence || "-" %>
                </div>
              </td>

              <td class="px-4 py-3 text-sm text-gray-700 max-w-md">
                <% if stream.youtube_ingestion_address.present? %>
                  <div class="flex items-center gap-2">
                    <span class="truncate max-w-[260px]"><%= stream.youtube_ingestion_address %></span>
                    <button
                      type="button"
                      class="text-xs bg-gray-200 hover:bg-gray-300 px-2 py-1 rounded"
                      onclick="navigator.clipboard.writeText('<%= j(stream.youtube_ingestion_address) %>')"
                    >
                      Copy
                    </button>
                  </div>
                <% else %>
                  -
                <% end %>
              </td>

              <td class="px-4 py-3 text-sm">
                <%= link_to "View",
                    production_operator_stream_path(stream),
                    class: "text-indigo-600 hover:text-indigo-800 font-medium" %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  <% else %>
    <p class="text-sm text-gray-500">No streams found.</p>
  <% end %>
</div>
