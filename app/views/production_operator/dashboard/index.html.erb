<div class="grid grid-cols-3 gap-6">
  
  <!-- LIVE STREAMS -->
  <div class="col-span-2 bg-white p-4 rounded shadow">
    <h2 class="text-lg font-semibold text-red-600">🔴 Live Streams</h2>

    <% if @live_streams.present? %>
      <ul class="mt-3 space-y-3">
        <% @live_streams.each do |stream| %>
          <li class="border rounded p-3 flex justify-between items-center">
            <div>
              <strong><%= stream.title %></strong>
              <div class="text-sm text-gray-500">
                <%= stream.youtube_channel&.name %>
              </div>
            </div>

            <div class="flex items-center space-x-3">
              <span class="text-xs bg-red-100 text-red-700 px-2 py-1 rounded">
                LIVE
              </span>

              <%= link_to "Manage",
                  production_operator_stream_path(stream),
                  class: "text-sm bg-gray-800 text-white px-3 py-1 rounded" %>
            </div>
          </li>
        <% end %>
      </ul>
    <% else %>
      <p class="text-sm text-gray-500 mt-2">No live streams currently.</p>
    <% end %>
  </div>

  <!-- UPCOMING STREAMS -->
  <aside class="bg-white p-4 rounded shadow">
    <h3 class="font-semibold">Upcoming Streams</h3>

    <% if @scheduled_streams.present? %>
      <ul class="mt-3 space-y-2">
        <% @scheduled_streams.each do |stream| %>
          <li class="text-sm border-b pb-2">
            <div class="font-medium"><%= stream.title %></div>
            <div class="text-xs text-gray-500">
              <%= stream.scheduled_at.strftime("%b %d, %H:%M") if stream.scheduled_at %>
            </div>
          </li>
        <% end %>
      </ul>
    <% else %>
      <p class="text-sm text-gray-500">No scheduled streams.</p>
    <% end %>
  </aside>

</div>

<!-- QUICK ACTIONS -->
<div class="mt-6 bg-white p-4 rounded shadow">
  <h3 class="font-semibold mb-3">Quick Actions</h3>

  <div class="flex space-x-4">
    <%= link_to "View All Streams",
        production_operator_streams_path,
        class: "bg-gray-800 text-white px-4 py-2 rounded" %>

    <%= link_to "Refresh Status",
        production_operator_dashboard_path,
        class: "bg-gray-200 px-4 py-2 rounded" %>
  </div>
</div>
