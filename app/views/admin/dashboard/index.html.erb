<!-- app/views/admin/dashboard/index.html.erb -->
<div class="grid grid-cols-3 gap-6">
  <div class="col-span-2 bg-white p-4 rounded shadow">
    <h2 class="text-lg font-semibold">Upcoming Streams</h2>
    <% if @upcoming_streams.present? %>
      <ul class="mt-3 space-y-2">
        <% @upcoming_streams.each do |s| %>
          <li class="border rounded p-2 flex justify-between">
            <div>
              <strong><%= s.title %></strong>
              <div class="text-sm text-gray-500"><%= s.try(:youtube_channel).try(:name) || s.try(:channel_name) %></div>
            </div>
            <div class="text-sm"><%= s.scheduled_at.strftime("%b %d, %Y %H:%M") if s.scheduled_at %></div>
          </li>
        <% end %>
      </ul>
    <% else %>
      <p class="text-sm text-gray-500">No upcoming streams.</p>
    <% end %>
  </div>

  <aside class="bg-white p-4 rounded shadow">
    <h3 class="font-semibold">Recent Channels</h3>
    <ul class="mt-3 space-y-2">
      <% @recent_channels.each do |c| %>
        <li class="text-sm">
          <%= link_to c.name, admin_youtube_channel_path(c), class: "font-medium" %>
          <div class="text-xs text-gray-500"><%= time_ago_in_words(c.created_at) %> ago</div>
        </li>
      <% end %>
    </ul>
  </aside>
</div>
