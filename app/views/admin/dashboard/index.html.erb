<div class="grid grid-cols-1 xl:grid-cols-3 gap-6">
  <div class="xl:col-span-2 space-y-6">
    <div class="bg-white border border-gray-200 rounded-2xl shadow-sm p-5">
      <div class="flex items-center justify-between mb-4">
        <div>
          <h2 class="text-lg font-semibold text-gray-900">Upcoming Streams</h2>
          <p class="text-sm text-gray-500">Streams scheduled for the next run.</p>
        </div>
      </div>

      <% if @upcoming_streams.present? %>
        <ul class="space-y-3">
          <% @upcoming_streams.each do |s| %>
            <li class="border border-gray-200 rounded-xl p-4 flex items-center justify-between gap-4">
              <div class="min-w-0">
                <div class="flex items-center gap-2">
                  <strong class="text-gray-900 truncate"><%= s.title %></strong>
                  <span class="text-xs px-2 py-1 rounded-full bg-gray-100 text-gray-600">
                    <%= s.status %>
                  </span>
                </div>
                <div class="text-sm text-gray-500 mt-1">
                  <%= s.try(:youtube_channel).try(:name) || s.try(:channel_name) || "No channel assigned" %>
                </div>
              </div>

              <div class="text-sm text-gray-600 whitespace-nowrap">
                <%= s.scheduled_at.strftime("%b %d, %Y %H:%M") if s.scheduled_at %>
              </div>
            </li>
          <% end %>
        </ul>
      <% else %>
        <div class="rounded-xl border border-dashed border-gray-300 p-8 text-center">
          <p class="text-sm text-gray-500">No upcoming streams.</p>
        </div>
      <% end %>
    </div>

    <div class="bg-white border border-gray-200 rounded-2xl shadow-sm p-5">
      <div class="flex items-center justify-between mb-4">
        <div>
          <h2 class="text-lg font-semibold text-gray-900">Recent Activity</h2>
          <p class="text-sm text-gray-500">Latest imported or updated channels.</p>
        </div>
      </div>

      <ul class="space-y-3">
        <% @recent_channels.each do |c| %>
          <li class="border border-gray-200 rounded-xl p-4 flex items-center justify-between gap-4">
            <div class="min-w-0">
              <div class="flex items-center gap-2">
                <%= link_to c.name, admin_youtube_channel_path(c), class: "font-medium text-gray-900 hover:underline truncate" %>
                <span class="text-xs px-2 py-1 rounded-full <%= c.connected? ? 'bg-green-50 text-green-700' : 'bg-yellow-50 text-yellow-700' %>">
                  <%= c.connection_state %>
                </span>
              </div>
              <div class="text-xs text-gray-500 mt-1">
                <%= time_ago_in_words(c.created_at) %> ago
              </div>
            </div>

            <div class="flex items-center gap-2">
              <% if c.connected? %>
                <%= link_to "Open", admin_youtube_channel_path(c), class: "inline-flex items-center rounded-lg border border-gray-300 px-3 py-2 text-sm font-medium text-gray-700 hover:bg-gray-50" %>
              <% else %>
                <%= link_to "Connect", connect_admin_youtube_channel_path(c), class: "inline-flex items-center rounded-lg bg-gray-900 px-3 py-2 text-sm font-medium text-white hover:bg-gray-800" %>
              <% end %>
            </div>
          </li>
        <% end %>
      </ul>
    </div>
  </div>

  <aside class="space-y-6">
    <div class="bg-white border border-gray-200 rounded-2xl shadow-sm p-5">
      <div class="flex items-center justify-between mb-4">
        <div>
          <h3 class="font-semibold text-gray-900">Recent Channels</h3>
          <p class="text-sm text-gray-500">Manage YouTube connections.</p>
        </div>
      </div>

      <ul class="space-y-3">
        <% @recent_channels.each do |c| %>
          <li class="rounded-xl border border-gray-200 p-4">
            <div class="flex items-start justify-between gap-3">
              <div class="min-w-0">
                <%= link_to c.name, admin_youtube_channel_path(c), class: "font-medium text-gray-900 hover:underline truncate block" %>
                <div class="text-xs text-gray-500 mt-1">
                  Owner: <%= c.owner_email %>
                </div>
                <div class="text-xs text-gray-500">
                  Status: <%= c.connection_state %>
                </div>
              </div>
            </div>

            <div class="mt-4 flex items-center gap-2">
              <%= link_to "View", admin_youtube_channel_path(c), class: "inline-flex items-center rounded-lg border border-gray-300 px-3 py-2 text-sm font-medium text-gray-700 hover:bg-gray-50" %>

              <% if c.connected? %>
                <%= button_to "Disconnect", disconnect_admin_youtube_channel_path(c), method: :post, class: "inline-flex items-center rounded-lg bg-red-600 px-3 py-2 text-sm font-medium text-white hover:bg-red-700" %>
              <% else %>
                <%= link_to "Connect", connect_admin_youtube_channel_path(c), class: "inline-flex items-center rounded-lg bg-gray-900 px-3 py-2 text-sm font-medium text-white hover:bg-gray-800" %>
              <% end %>
            </div>
          </li>
        <% end %>
      </ul>
    </div>
  </aside>
</div>
