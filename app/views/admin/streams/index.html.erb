<div class="flex items-center justify-between mb-4">
  <div>
    <h1 class="text-2xl font-bold">Streams</h1>
    <p class="text-sm text-gray-600">
      Pending YouTube syncs: <%= @pending_sync_count %>
    </p>
  </div>

  <% if @pending_sync_count.positive? %>
    <%= button_to "Sync all pending to YouTube",
        sync_pending_to_youtube_admin_streams_path,
        method: :post,
        class: "bg-blue-600 text-white px-4 py-2 rounded hover:bg-blue-700" %>
  <% end %>
</div>

<% if @imported_streams.present? %>
  <div class="mb-8 rounded-2xl border border-emerald-200 bg-emerald-50 p-4">
    <h2 class="text-lg font-semibold text-emerald-900 mb-3">Recently imported streams</h2>
    <div class="space-y-3">
      <% @imported_streams.each do |s| %>
        <div class="rounded-xl border border-emerald-200 bg-white p-4 shadow-sm">
          <div class="flex items-start justify-between gap-4">
            <div>
              <p class="font-semibold text-gray-900">
                <%= link_to s.title, admin_stream_path(s), class: "hover:underline" %>
              </p>
              <p class="text-sm text-gray-600"><%= s.youtube_channel&.name || "No channel selected" %></p>
            </div>
            <span class="rounded-full bg-emerald-100 px-2 py-1 text-xs font-medium text-emerald-700">
              Imported
            </span>
          </div>
        </div>
      <% end %>
    </div>
  </div>
<% end %>

<% if @streams.any? %>
  <table class="min-w-full bg-white">
    <thead>
      <tr>
        <th class="px-4 py-2 text-left">Title</th>
        <th class="px-4 py-2 text-left">Channel</th>
        <th class="px-4 py-2 text-left">Status</th>
        <th class="px-4 py-2 text-left">Visibility</th>
        <th class="px-4 py-2 text-left">Sync</th>
        <th class="px-4 py-2 text-left">Scheduled</th>
        <th class="px-4 py-2"></th>
      </tr>
    </thead>
    <tbody>
      <% @streams.each do |s| %>
        <tr class="border-t">
          <td class="px-4 py-2">
            <%= link_to s.title, admin_stream_path(s), class: "text-blue-600 hover:underline" %>
          </td>
          <td class="px-4 py-2"><%= s.youtube_channel&.name %></td>
          <td class="px-4 py-2"><%= s.status.titleize %></td>
          <td class="px-4 py-2"><%= s.visibility.titleize %></td>
          <td class="px-4 py-2">
            <% if s.synced? %>
              <span class="inline-flex rounded-full bg-green-100 px-2 py-1 text-xs font-medium text-green-800">
                Synced
              </span>
            <% elsif s.syncing? %>
              <span class="inline-flex rounded-full bg-yellow-100 px-2 py-1 text-xs font-medium text-yellow-800">
                Syncing
              </span>
            <% elsif s.failed_sync? %>
              <span class="inline-flex rounded-full bg-red-100 px-2 py-1 text-xs font-medium text-red-800">
                Failed
              </span>
            <% else %>
              <span class="inline-flex rounded-full bg-gray-100 px-2 py-1 text-xs font-medium text-gray-700">
                Pending
              </span>
            <% end %>
          </td>
          <td class="px-4 py-2"><%= s.scheduled_at_local&.strftime("%b %d, %H:%M") || "—" %></td>
          <td class="px-4 py-2 text-right whitespace-nowrap">
            <% if s.pending_sync? || s.failed_sync? %>
              <%= button_to "Sync",
                  sync_to_youtube_admin_stream_path(s),
                  method: :post,
                  class: "text-sm text-blue-600 inline-block mr-3" %>
            <% end %>

            <%= link_to "Edit", edit_admin_stream_path(s), class: "text-sm text-blue-600" %>
            <%= link_to "Delete",
                admin_stream_path(s),
                data: { turbo_method: :delete, turbo_confirm: "Are you sure?" },
                class: "text-sm text-red-600 ml-3" %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>

  <div class="mt-4">
    <%= paginate @streams %>
  </div>
<% else %>
  <div class="rounded-2xl border border-gray-200 bg-white p-6 text-sm text-gray-600">
    No older streams to show right now.
  </div>
<% end %>
