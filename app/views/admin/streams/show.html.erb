<div class="min-h-screen bg-slate-100 px-4 py-10 sm:px-6 lg:px-8" data-controller="modal">
  <div class="mx-auto max-w-6xl">
    <div class="mb-6 flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
      <div>
        <p class="text-sm font-medium uppercase tracking-[0.2em] text-slate-500">
        Stream
        </p>
        <h1 class="mt-2 text-3xl font-semibold tracking-tight text-slate-900 sm:text-4xl">
          <%= @stream.title %>
        </h1>
        <p class="mt-2 text-sm text-slate-600">
          Detailed overview of this scheduled stream and its sync status.
        </p>
      </div>

      <div class="flex flex-wrap items-center gap-3">
        <%= link_to "Back to streams",
                    admin_streams_path,
                    class: "inline-flex items-center justify-center rounded-xl border border-slate-200 bg-white px-4 py-2.5 text-sm font-medium text-slate-700 shadow-sm transition hover:border-slate-300 hover:bg-slate-50 hover:text-slate-900 focus:outline-none focus:ring-2 focus:ring-cyan-400 focus:ring-offset-2 focus:ring-offset-slate-100" %>

        <button
          type="button"
          data-action="click->modal#open"
          class="inline-flex items-center justify-center rounded-xl bg-cyan-500 px-4 py-2.5 text-sm font-semibold text-slate-950 shadow-lg shadow-cyan-500/20 transition hover:bg-cyan-400 focus:outline-none focus:ring-2 focus:ring-cyan-400 focus:ring-offset-2 focus:ring-offset-slate-100"
        >
          Edit stream
        </button>

        <% if @stream.pending_sync? || @stream.failed_sync? %>
          <%= button_to sync_to_youtube_admin_stream_path(@stream),
                        method: :post,
                        form: { class: "inline-flex" },
                        class: "inline-flex items-center justify-center rounded-xl border border-cyan-200 bg-cyan-50 px-4 py-2.5 text-sm font-medium text-cyan-700 shadow-sm transition hover:border-cyan-300 hover:bg-cyan-100 hover:text-cyan-800 focus:outline-none focus:ring-2 focus:ring-cyan-400 focus:ring-offset-2 focus:ring-offset-slate-100" do %>
            Sync to YouTube
          <% end %>
        <% end %>

        <%= button_to admin_stream_path(@stream),
                      method: :delete,
                      form: { class: "inline-flex" },
                      data: { turbo_confirm: "Are you sure you want to delete this stream?" },
                      class: "inline-flex items-center justify-center rounded-xl border border-red-200 bg-red-50 px-4 py-2.5 text-sm font-medium text-red-700 shadow-sm transition hover:border-red-300 hover:bg-red-100 hover:text-red-800 focus:outline-none focus:ring-2 focus:ring-red-400 focus:ring-offset-2 focus:ring-offset-slate-100" do %>
          Delete
        <% end %>
      </div>
    </div>

    <div class="grid gap-6 lg:grid-cols-3">
      <div class="space-y-6 lg:col-span-2">
        <div class="overflow-hidden rounded-3xl border border-slate-200 bg-white shadow-sm">
          <div class="border-b border-slate-200 px-6 py-5">
            <h2 class="text-lg font-semibold text-slate-900">Stream details</h2>
            <p class="mt-1 text-sm text-slate-600">
              Core information used for scheduling and publishing.
            </p>
          </div>

          <div class="grid gap-0 divide-y divide-slate-200 sm:grid-cols-2 sm:divide-x sm:divide-y-0">
            <div class="p-6">
              <p class="text-xs font-semibold uppercase tracking-[0.18em] text-slate-500">Title</p>
              <p class="mt-2 text-sm text-slate-900"><%= @stream.title %></p>
            </div>

            <div class="p-6">
              <p class="text-xs font-semibold uppercase tracking-[0.18em] text-slate-500">YouTube channel</p>
              <p class="mt-2 text-sm text-slate-900"><%= @stream.youtube_channel&.name || "No channel selected" %></p>
            </div>

            <div class="p-6">
              <p class="text-xs font-semibold uppercase tracking-[0.18em] text-slate-500">Status</p>
              <p class="mt-2 text-sm text-slate-900"><%= @stream.status.titleize %></p>
            </div>

            <div class="p-6">
              <p class="text-xs font-semibold uppercase tracking-[0.18em] text-slate-500">Visibility</p>
              <p class="mt-2 text-sm text-slate-900"><%= @stream.visibility.titleize %></p>
            </div>

            <div class="p-6">
              <p class="text-xs font-semibold uppercase tracking-[0.18em] text-slate-500">Scheduled for</p>
              <p class="mt-2 text-sm text-slate-900">
                <%= @stream.scheduled_at_local&.strftime("%A, %b %d %Y at %H:%M") || "—" %>
              </p>
            </div>

            <div class="p-6">
              <p class="text-xs font-semibold uppercase tracking-[0.18em] text-slate-500">Sync status</p>
              <div class="mt-2">
                <% if @stream.synced? %>
                  <span class="inline-flex rounded-full bg-emerald-100 px-3 py-1 text-xs font-medium text-emerald-700">
                    Synced
                  </span>
                <% elsif @stream.syncing? %>
                  <span class="inline-flex rounded-full bg-amber-100 px-3 py-1 text-xs font-medium text-amber-700">
                    Syncing
                  </span>
                <% elsif @stream.failed_sync? %>
                  <span class="inline-flex rounded-full bg-red-100 px-3 py-1 text-xs font-medium text-red-700">
                    Failed
                  </span>
                <% else %>
                  <span class="inline-flex rounded-full bg-slate-100 px-3 py-1 text-xs font-medium text-slate-700">
                    Pending
                  </span>
                <% end %>
              </div>
            </div>
          </div>
        </div>

        <div class="overflow-hidden rounded-3xl border border-slate-200 bg-white shadow-sm">
          <div class="border-b border-slate-200 px-6 py-5">
            <h2 class="text-lg font-semibold text-slate-900">Description</h2>
            <p class="mt-1 text-sm text-slate-600">
              Content that will be used for the stream on YouTube.
            </p>
          </div>

          <div class="px-6 py-6">
            <% if @stream.description.present? %>
              <p class="whitespace-pre-line text-sm leading-6 text-slate-700"><%= @stream.description %></p>
            <% else %>
              <p class="text-sm text-slate-500">No description has been added yet.</p>
            <% end %>
          </div>
        </div>
      </div>

      <div class="space-y-6">
        <div class="overflow-hidden rounded-3xl border border-slate-200 bg-white shadow-sm">
          <div class="border-b border-slate-200 px-6 py-5">
            <h2 class="text-lg font-semibold text-slate-900">Quick stats</h2>
          </div>

          <div class="space-y-4 px-6 py-6">
            <div>
              <p class="text-xs font-semibold uppercase tracking-[0.18em] text-slate-500">Created</p>
              <p class="mt-2 text-sm text-slate-900"><%= @stream.created_at.strftime("%b %d, %Y at %H:%M") %></p>
            </div>

            <div>
              <p class="text-xs font-semibold uppercase tracking-[0.18em] text-slate-500">Updated</p>
              <p class="mt-2 text-sm text-slate-900"><%= @stream.updated_at.strftime("%b %d, %Y at %H:%M") %></p>
            </div>

            <% if @stream.respond_to?(:youtube_id) && @stream.youtube_id.present? %>
              <div>
                <p class="text-xs font-semibold uppercase tracking-[0.18em] text-slate-500">YouTube ID</p>
                <p class="mt-2 break-all text-sm text-slate-900"><%= @stream.youtube_id %></p>
              </div>
            <% end %>

            <% if @stream.respond_to?(:youtube_url) && @stream.youtube_url.present? %>
              <div>
                <p class="text-xs font-semibold uppercase tracking-[0.18em] text-slate-500">YouTube URL</p>
                <%= link_to @stream.youtube_url,
                            @stream.youtube_url,
                            target: "_blank",
                            rel: "noopener",
                            class: "mt-2 block break-all text-sm text-cyan-700 hover:underline" %>
              </div>
            <% end %>
          </div>
        </div>

        <div class="rounded-3xl border border-slate-200 bg-slate-950 p-6 text-slate-100 shadow-sm">
          <p class="text-sm font-semibold uppercase tracking-[0.18em] text-slate-400">Workflow</p>
          <ol class="mt-4 space-y-3 text-sm text-slate-300">
            <li class="flex gap-3">
              <span class="mt-0.5 flex h-6 w-6 shrink-0 items-center justify-center rounded-full bg-cyan-500 text-xs font-bold text-slate-950">1</span>
              Review the stream details.
            </li>
            <li class="flex gap-3">
              <span class="mt-0.5 flex h-6 w-6 shrink-0 items-center justify-center rounded-full bg-cyan-500 text-xs font-bold text-slate-950">2</span>
              Edit any title, date, or channel issues.
            </li>
            <li class="flex gap-3">
              <span class="mt-0.5 flex h-6 w-6 shrink-0 items-center justify-center rounded-full bg-cyan-500 text-xs font-bold text-slate-950">3</span>
              Sync to YouTube once everything is correct.
            </li>
          </ol>
        </div>
      </div>
    </div>
  </div>

  <div
    data-modal-target="dialog"
    class="hidden fixed inset-0 z-50"
    aria-hidden="true"
  >
    <div
      class="absolute inset-0 bg-slate-950/60"
      data-action="click->modal#close"
    ></div>

    <div class="relative z-10 flex min-h-full items-center justify-center p-4">
      <div
        data-modal-target="panel"
        class="w-full max-w-4xl overflow-hidden rounded-3xl border border-slate-200 bg-white shadow-2xl opacity-0 scale-95 translate-y-4 transition-all duration-150"
        role="dialog"
        aria-modal="true"
        aria-labelledby="edit-stream-title"
      >
        <div class="flex items-center justify-between border-b border-slate-200 px-6 py-5">
          <div>
            <h2 id="edit-stream-title" class="text-xl font-semibold tracking-tight text-slate-900">
              Edit stream
            </h2>
          </div>

          <button
            type="button"
            class="inline-flex h-10 w-10 items-center justify-center rounded-full border border-slate-200 bg-white text-slate-500 transition hover:bg-slate-50 hover:text-slate-900"
            aria-label="Close modal"
            data-action="click->modal#close"
          >
            ✕
          </button>
        </div>

        <div class="px-6 py-6">
          <%= render "form", stream: @stream, youtube_channels: @youtube_channels %>
        </div>
      </div>
    </div>
  </div>
</div>
