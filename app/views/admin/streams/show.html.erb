<div class="bg-white p-6 rounded shadow">
  <h1 class="text-2xl font-semibold mb-2"><%= @stream.title %></h1>
  <div class="text-sm text-gray-600 mb-4">
    Channel: <strong><%= @stream.youtube_channel&.name %></strong> |
    Status: <strong><%= @stream.status %></strong> |
    Visibility: <strong><%= @stream.visibility %></strong>
  </div>

  <div class="mb-4">
    <h3 class="font-semibold">Description</h3>
    <p class="text-sm text-gray-700"><%= simple_format(@stream.description || "—") %></p>
  </div>

  <div class="mb-4">
    <h3 class="font-semibold">Scheduled at</h3>
    <div><%= @stream.scheduled_at_local&.strftime("%B %d, %H:%M %Z") || "Not scheduled" %></div>
  </div>

  <% if @stream.external_video_id.present? %>
    <div class="mb-4">
      <h3 class="font-semibold">YouTube broadcast</h3>
      <p class="text-sm text-gray-700">External ID: <%= @stream.external_video_id %></p>
    </div>
  <% end %>

  <div class="flex space-x-3">
    <%= link_to "Edit", edit_admin_stream_path(@stream), class: "bg-gray-800 text-white px-4 py-2 rounded" %>
    <%= link_to "Back", admin_streams_path, class: "px-4 py-2 rounded border" %>
  </div>
</div>
