<div class="flex min-h-[70vh] items-center justify-center">
  <div class="w-full max-w-md rounded-3xl border border-gray-200 bg-white p-8 shadow-lg text-center">

    <div class="mb-6">
      <div class="mx-auto mb-4 h-12 w-12 animate-spin rounded-full border-4 border-gray-200 border-t-black"></div>
      <h2 class="text-xl font-semibold text-gray-900">Processing Schedule</h2>
      <p class="mt-2 text-sm text-gray-600">
        Parsing PDF and preparing streams...
      </p>
    </div>

    <div class="mb-4">
      <div class="h-2 w-full rounded-full bg-gray-200 overflow-hidden">
        <div id="progress-bar" class="h-full bg-black transition-all duration-500" style="width: 10%"></div>
      </div>
    </div>

    <p id="status-text" class="text-xs text-gray-500">
      Starting...
    </p>
  </div>
</div>

<script>
  let progress = 10;

  function updateProgress(status, aiStatus) {
    const bar = document.getElementById("progress-bar");
    const text = document.getElementById("status-text");

    if (status === "completed") {
      progress = 100;
      bar.style.width = "100%";
      text.innerText = "Finalizing...";

      setTimeout(() => {
        window.location.href = "<%= admin_schedule_import_path(@schedule_import) %>";
      }, 500);
      return;
    }

    if (status === "parsed" && aiStatus === "processing") {
      progress = 70;
      text.innerText = "Cleaning streams with AI...";
    }

    else if (status === "processing") {
      progress = Math.min(progress + 5, 60);
      text.innerText = "Parsing PDF...";
    }


    else {
      progress = Math.min(progress + 5, 60);
      text.innerText = "Processing...";
    }

    bar.style.width = progress + "%";
  }

  async function pollStatus() {
    try {
      const res = await fetch("<%= status_admin_schedule_import_path(@schedule_import) %>");
      const data = await res.json();

      updateProgress(data.status, data.ai_status);

      if (data.status !== "completed") {
        setTimeout(pollStatus, 2000);
      }
    } catch (e) {
      console.error(e);
      setTimeout(pollStatus, 3000);
    }
  }

  pollStatus();
</script>
