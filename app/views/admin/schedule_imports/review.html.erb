<div class="max-w-6xl mx-auto px-4 py-8">
  <h1 class="text-2xl font-bold mb-2">Review AI-cleaned schedule items</h1>
  <p class="text-sm text-gray-600 mb-6">
    Edit anything that looks off, then create the streams.
  </p>

  <%= form_with url: confirm_schedule_import_path(@schedule_import), method: :post do %>
    <% @cleaned_rows.each_with_index do |row, index| %>
      <% raw_row = @raw_rows[index] || {} %>

      <div class="border rounded-lg p-4 mb-6 bg-white shadow-sm">
        <div class="flex items-center justify-between mb-4">
          <h2 class="text-lg font-semibold">Item <%= index + 1 %></h2>
          <span class="text-xs px-2 py-1 rounded bg-gray-100">AI cleaned</span>
        </div>

        <%= hidden_field_tag "schedule_import[rows][#{index}][index]", row["index"] %>
        <%= hidden_field_tag "schedule_import[rows][#{index}][raw_title]", row["raw_title"] %>
        <%= hidden_field_tag "schedule_import[rows][#{index}][raw_description]", row["raw_description"] %>

        <div class="grid md:grid-cols-2 gap-4">
          <div>
            <%= label_tag nil, "Title", class: "block text-sm font-medium mb-1" %>
            <%= text_field_tag "schedule_import[rows][#{index}][title]", row["title"], class: "w-full border rounded p-2" %>
          </div>

          <div>
            <%= label_tag nil, "Visibility", class: "block text-sm font-medium mb-1" %>
            <%= select_tag "schedule_import[rows][#{index}][visibility]",
                options_for_select([["Public", "public"], ["Unlisted", "unlisted"]], row["visibility"]),
                class: "w-full border rounded p-2" %>
          </div>

          <div class="md:col-span-2">
            <%= label_tag nil, "Description", class: "block text-sm font-medium mb-1" %>
            <%= text_area_tag "schedule_import[rows][#{index}][description]", row["description"], rows: 4, class: "w-full border rounded p-2" %>
          </div>

          <div>
            <%= label_tag nil, "Committee", class: "block text-sm font-medium mb-1" %>
            <%= text_field_tag "schedule_import[rows][#{index}][committee]", row["committee"], class: "w-full border rounded p-2" %>
          </div>

          <div>
            <%= label_tag nil, "Location", class: "block text-sm font-medium mb-1" %>
            <%= text_field_tag "schedule_import[rows][#{index}][location]", row["location"], class: "w-full border rounded p-2" %>
          </div>

          <div>
            <%= label_tag nil, "Date text", class: "block text-sm font-medium mb-1" %>
            <%= text_field_tag "schedule_import[rows][#{index}][date_text]", row["date_text"], class: "w-full border rounded p-2" %>
          </div>

          <div>
            <%= label_tag nil, "Time text", class: "block text-sm font-medium mb-1" %>
            <%= text_field_tag "schedule_import[rows][#{index}][time_text]", row["time_text"], class: "w-full border rounded p-2" %>
          </div>

          <div class="md:col-span-2">
            <%= label_tag nil, "Scheduled at", class: "block text-sm font-medium mb-1" %>
            <%= text_field_tag "schedule_import[rows][#{index}][scheduled_at]", row["scheduled_at"], class: "w-full border rounded p-2", placeholder: "2026-03-20 10:00" %>
          </div>

          <div class="md:col-span-2">
            <%= label_tag nil, "Notes", class: "block text-sm font-medium mb-1" %>
            <%= text_area_tag "schedule_import[rows][#{index}][notes]", row["notes"], rows: 2, class: "w-full border rounded p-2" %>
          </div>
        </div>

        <details class="mt-4">
          <summary class="cursor-pointer text-sm text-gray-700">Show raw parser output</summary>
          <pre class="mt-3 p-3 bg-gray-50 border rounded overflow-x-auto text-xs"><%= JSON.pretty_generate(raw_row) %></pre>
        </details>
      </div>
    <% end %>

    <div class="mt-6">
      <%= submit_tag "Create Streams", class: "px-4 py-2 rounded bg-black text-white" %>
    </div>
  <% end %>
</div>
