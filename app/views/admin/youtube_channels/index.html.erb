<div class="bg-white border border-gray-200 rounded-2xl shadow-sm p-6">
  <div class="flex items-center justify-between mb-6">
    <div>
      <h1 class="text-2xl font-bold text-gray-900">Channels</h1>
      <p class="text-sm text-gray-500">Manage YouTube channel connections and metadata.</p>
    </div>

    <%= link_to "New Channel",
                new_admin_youtube_channel_path,
                class: "inline-flex items-center rounded-lg bg-gray-900 px-4 py-2 text-sm font-medium text-white hover:bg-gray-800" %>
  </div>

  <% if @youtube_channels.present? %>
    <div class="overflow-hidden rounded-xl border border-gray-200">
      <table class="min-w-full divide-y divide-gray-200">
        <thead class="bg-gray-50">
          <tr>
            <th class="px-4 py-3 text-left text-xs font-semibold uppercase tracking-wider text-gray-500">Name</th>
            <th class="px-4 py-3 text-left text-xs font-semibold uppercase tracking-wider text-gray-500">Owner</th>
            <th class="px-4 py-3 text-left text-xs font-semibold uppercase tracking-wider text-gray-500">Connection</th>
            <th class="px-4 py-3 text-right text-xs font-semibold uppercase tracking-wider text-gray-500">Actions</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-200 bg-white">
          <% @youtube_channels.each do |channel| %>
            <tr>
              <td class="px-4 py-3">
                <%= link_to channel.name, admin_youtube_channel_path(channel), class: "font-medium text-gray-900 hover:underline" %>
              </td>
              <td class="px-4 py-3 text-sm text-gray-700"><%= channel.owner_email %></td>
              <td class="px-4 py-3">
                <span class="inline-flex rounded-full px-2.5 py-1 text-xs font-medium <%= channel.connection_badge_class %>">
                  <%= channel.connection_state %>
                </span>
              </td>
              <td class="px-4 py-3 text-right">
                <%= link_to "View",
                            admin_youtube_channel_path(channel),
                            class: "inline-flex items-center rounded-lg border border-gray-300 px-3 py-2 text-sm font-medium text-gray-700 hover:bg-gray-50" %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  <% else %>
    <div class="rounded-xl border border-dashed border-gray-300 p-8 text-center">
      <p class="text-sm text-gray-500">No channels created yet.</p>
    </div>
  <% end %>
</div>
